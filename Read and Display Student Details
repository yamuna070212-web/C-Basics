#include <stdio.h>

int main()
{
    char name[30];
    int age;

    printf("Enter your name: ");
    scanf("%s", name);

    printf("Enter your age: ");
    scanf("%d", &age);

    printf("\nStudent Details");
    printf("\nName : %s", name);
    printf("\nAge  : %d", age);

    return 0;
}
