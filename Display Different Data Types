#include <stdio.h>

int main()
{
    int id = 101;
    float salary = 35000.75;
    char section = 'B';

    printf("Employee ID : %d\n", id);
    printf("Salary      : %.2f\n", salary);
    printf("Section     : %c", section);

    return 0;
}
Output
Employee ID : 101
Salary      : 35000.75
Section     : B
