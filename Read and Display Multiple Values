#include <stdio.h>

int main()
{
    int roll;
    float marks;
    char grade;

    printf("Enter Roll Number: ");
    scanf("%d", &roll);

    printf("Enter Marks: ");
    scanf("%f", &marks);

    printf("Enter Grade: ");
    scanf(" %c", &grade);

    printf("\nRoll Number = %d", roll);
    printf("\nMarks = %.2f", marks);
    printf("\nGrade = %c", grade);

    return 0;
}
